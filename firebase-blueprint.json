{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User preferences and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "theme": { "type": "string", "description": "Selected theme ID" },
        "streak": { "type": "number", "description": "Current habit streak" },
        "productivityScore": { "type": "number", "description": "Weekly productivity score" },
        "plan": { "type": "string", "description": "Subscription plan" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "A user task or to-do item",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "title": { "type": "string", "description": "Task title" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"], "description": "Task priority" },
        "completed": { "type": "boolean", "description": "Completion status" },
        "dueDate": { "type": "string", "format": "date-time", "description": "Task due date" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "title", "priority", "completed"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A recurring habit to track",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "title": { "type": "string", "description": "Habit title" },
        "icon": { "type": "string", "description": "Icon name" },
        "frequency": { "type": "string", "description": "Frequency (e.g., Daily)" },
        "time": { "type": "string", "description": "Time of day" },
        "streak": { "type": "number", "description": "Current streak" },
        "progress": { "type": "number", "description": "Current progress" },
        "target": { "type": "number", "description": "Target value" },
        "unit": { "type": "string", "description": "Unit of measurement" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last check-in timestamp" }
      },
      "required": ["uid", "title", "icon", "target", "unit"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "merchant": { "type": "string", "description": "Merchant name" },
        "category": { "type": "string", "description": "Transaction category" },
        "amount": { "type": "number", "description": "Transaction amount" },
        "type": { "type": "string", "enum": ["expense", "income"], "description": "Transaction type" },
        "date": { "type": "string", "format": "date-time", "description": "Transaction date" }
      },
      "required": ["uid", "merchant", "category", "amount", "type", "date"]
    },
    "AIMessage": {
      "title": "AI Message",
      "description": "A message in the AI chat",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "role": { "type": "string", "enum": ["user", "ai"], "description": "Message sender" },
        "text": { "type": "string", "description": "Message content" },
        "time": { "type": "string", "description": "Display time" },
        "insights": { "type": "boolean", "description": "Whether it contains insights" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "tasks": { "schema": "Task", "description": "User tasks" },
    "habits": { "schema": "Habit", "description": "User habits" },
    "transactions": { "schema": "Transaction", "description": "User financial transactions" },
    "ai_messages": { "schema": "AIMessage", "description": "AI chat history" }
  }
}
